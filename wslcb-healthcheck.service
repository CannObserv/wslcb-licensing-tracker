[Unit]
Description=WSLCB web app periodic health check
After=wslcb-web.service

[Service]
Type=oneshot
User=exedev
# Curl the health endpoint; restart the web service if it returns non-200.
# Requires /etc/sudoers.d/wslcb-healthcheck granting exedev passwordless
# sudo for this exact command (see AGENTS.md deployment section).
ExecStart=/bin/bash -c '/usr/bin/curl -sf http://localhost:8000/api/v1/health || /usr/bin/sudo /usr/bin/systemctl restart wslcb-web.service'
