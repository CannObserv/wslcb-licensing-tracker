# Environment variables consumed by the WSLCB Licensing Tracker.
# Copy to .env for local development (the repo .env is gitignored).
# Production values live in /etc/wslcb-licensing-tracker/.env (systemd EnvironmentFile).

# ── Application ──────────────────────────────────────────────────────
# PostgreSQL connection URL (SQLAlchemy async driver).
DATABASE_URL=postgresql+asyncpg://wslcb:wslcb@localhost/wslcb

# Root of the snapshot/diff archive tree. Defaults to <repo>/data when unset.
#DATA_DIR=/home/exedev/wslcb-licensing-tracker/data

# Short git SHA used for static-asset cache busting. Set by the systemd unit
# in production (see infra/wslcb-web.service); unset in dev → "dev".
#BUILD_ID=

# ── Address validation (optional) ────────────────────────────────────
# Master switch for the address-validator integration ("1"/"true"/"yes").
#ENABLE_ADDRESS_VALIDATION=1
# API key for https://address-validator.exe.xyz:8000
#ADDRESS_VALIDATOR_API_KEY=

# ── Admin auth (dev only — NEVER set in production) ──────────────────
# Fallback identity when exe.dev proxy headers are absent, e.g. when
# hitting uvicorn directly on localhost.
#ADMIN_DEV_EMAIL=you@example.com
#ADMIN_DEV_USERID=dev

# ── Tests ────────────────────────────────────────────────────────────
# Separate PostgreSQL database for the test suite (required for PG tests;
# tests are skipped when unset).
TEST_DATABASE_URL=postgresql+asyncpg://wslcb:wslcb@localhost/wslcb_test
# CI only: turn missing TEST_DATABASE_URL into a hard failure.
#REQUIRE_PG_TESTS=1

# ── Agent / dev tooling (not read by the application) ────────────────
# GitHub PAT used by the gh CLI for issues/PRs.
#GH_TOKEN=
# PAT for the gregoryfoster/skills vendor repo refresh.
#GH_TOKEN_GF_SKILLS=
